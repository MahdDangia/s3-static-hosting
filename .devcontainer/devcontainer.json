{
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {}
}

{
  "name": "DevOps Toolset",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu", 

  "features": {
    // 1. Installs Terraform
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    // 2. Installs AWS CLI (v2)
    "ghcr.io/devcontainers/features/aws-cli:1": {
      "version": "latest"
    },
    // 3. Installs Python 3, pip, and common development tools
    "ghcr.io/devcontainers/features/python:1": {
      "version": "latest"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        // Auto-formats Terraform files on save
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "hashicorp.terraform",
        "terraform.languageServer.enable": true
      },
      "extensions": [
        // Terraform autocomplete and syntax highlighting
        "hashicorp.terraform",
        // Python autocomplete, linting, and debugging
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  // Prints the installed versions in the terminal to verify success upon startup
  "postCreateCommand": "echo '=== Verification ===' && terraform --version && aws --version && python3 --version && pip3 --version"
}
